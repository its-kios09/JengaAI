# Jenga-AI Backend Environment Variables
# Copy to .env and fill in values

# App
DEBUG=false

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/jenga_ai

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT Secret (CHANGE THIS IN PRODUCTION — use: python -c "import secrets; print(secrets.token_urlsafe(32))")
SECRET_KEY=CHANGE-ME-IN-PRODUCTION
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# File uploads
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=500

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# MLflow (optional)
# MLFLOW_TRACKING_URI=http://localhost:5000
